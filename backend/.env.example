APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Added http:// for protocol consistency
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=peer_support
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Changed from null to localhost for local dev consistency
SESSION_DOMAIN=localhost

# Use `reverb` for realtime forum comments; run `php artisan reverb:start`.
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=reverb-app
REVERB_APP_KEY=reverb-key
REVERB_APP_SECRET=reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Google API Configuration
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

VITE_APP_NAME="${APP_NAME}"

# --- CORS & Sanctum Configuration ---
# Match the local Vite port
FRONTEND_URL=http://localhost:5173
# Required for SPA Authentication (Sanctum)
SANCTUM_STATEFUL_DOMAINS=localhost:5173

SESSION_SECURE_COOKIE=false
SESSION_SAMESITE=lax

# --- Production checklist ---
# 1. Set APP_URL to your API base; align FRONTEND_URL and SANCTUM stateful domains.
# 2. Use SESSION_DOMAIN / SESSION_SECURE_COOKIE as required for HTTPS.
# 3. Uncomment QUEUE_CONNECTION=redis and CACHE_STORE=redis above (requires Redis server).
# 4. Run Reverb with TLS (REVERB_SCHEME=https), put it behind your reverse proxy, and supervise `php artisan reverb:start`.
# 5. Trust proxies so request()->ip() is correct behind a load balancer (bootstrap/app.php / TrustProxies).

# 6. Run php artisan config:cache to cache configs (env() calls in controllers must use config() instead).